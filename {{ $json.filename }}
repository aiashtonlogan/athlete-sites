<style>
  /* ============================================================
     CSS VARIABLES — ALL COLORS AND FONTS TOKENIZED
  ============================================================ */
  :root {
    /* PALETTE: Void */
    --bg: #080808;
    --fg: #f0ede8;
    --accent: #c8a96e;
    --bg-secondary: #111111;
    --bg-card: #141414;
    --border: rgba(200, 169, 110, 0.2);
    --fg-muted: rgba(240, 237, 232, 0.5);
    --fg-subtle: rgba(240, 237, 232, 0.25);

    /* TYPOGRAPHY */
    --font-display: 'Oswald', sans-serif;
    --font-body: 'DM Sans', sans-serif;

    /* SPACING */
    --section-pad: clamp(80px, 10vw, 140px);
    --container: 1200px;
    --nav-h: 72px;

    /* TRANSITIONS */
    --trans: 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    --trans-slow: 0.6s cubic-bezier(0.4, 0, 0.2, 1);
  }

  /* FONT MODES */
  [data-font="athletic"] {
    --font-display: 'Oswald', sans-serif;
    --font-body: 'DM Sans', sans-serif;
  }
  [data-font="editorial"] {
    --font-display: 'Playfair Display', serif;
    --font-body: 'Libre Baskerville', serif;
  }
  [data-font="modern"] {
    --font-display: 'Space Grotesk', sans-serif;
    --font-body: 'Inter', sans-serif;
  }

  /* PALETTE OVERRIDES */
  [data-palette="void"] {
    --bg: #080808;
    --fg: #f0ede8;
    --accent: #c8a96e;
    --bg-secondary: #111111;
    --bg-card: #141414;
    --border: rgba(200, 169, 110, 0.2);
    --fg-muted: rgba(240, 237, 232, 0.5);
    --fg-subtle: rgba(240, 237, 232, 0.25);
  }
  [data-palette="carbon"] {
    --bg: #0f0f0f;
    --fg: #e8e8e8;
    --accent: #ff3b30;
    --bg-secondary: #1a1a1a;
    --bg-card: #1e1e1e;
    --border: rgba(255, 59, 48, 0.2);
    --fg-muted: rgba(232, 232, 232, 0.5);
    --fg-subtle: rgba(232, 232, 232, 0.25);
  }
  [data-palette="studio"] {
    --bg: #fafaf8;
    --fg: #0a0a0a;
    --accent: #dc2626;
    --bg-secondary: #f0efed;
    --bg-card: #f5f4f2;
    --border: rgba(220, 38, 38, 0.2);
    --fg-muted: rgba(10, 10, 10, 0.5);
    --fg-subtle: rgba(10, 10, 10, 0.2);
  }
  [data-palette="chalk"] {
    --bg: #f5f5f0;
    --fg: #111111;
    --accent: #2563eb;
    --bg-secondary: #ebebea;
    --bg-card: #eeeee9;
    --border: rgba(37, 99, 235, 0.2);
    --fg-muted: rgba(17, 17, 17, 0.5);
    --fg-subtle: rgba(17, 17, 17, 0.2);
  }
  [data-palette="storm"] {
    --bg: #1a1f2e;
    --fg: #d1d9e6;
    --accent: #f59e0b;
    --bg-secondary: #222839;
    --bg-card: #252c40;
    --border: rgba(245, 158, 11, 0.2);
    --fg-muted: rgba(209, 217, 230, 0.5);
    --fg-subtle: rgba(209, 217, 230, 0.25);
  }
  [data-palette="linen"] {
    --bg: #f0ebe3;
    --fg: #1a1a1a;
    --accent: #0f7558;
    --bg-secondary: #e8e2d9;
    --bg-card: #ece6de;
    --border: rgba(15, 117, 88, 0.2);
    --fg-muted: rgba(26, 26, 26, 0.5);
    --fg-subtle: rgba(26, 26, 26, 0.2);
  }

  /* ============================================================
     RESET & BASE
  ============================================================ */
  *, *::before, *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  html {
    scroll-behavior: smooth;
    font-size: 16px;
    -webkit-text-size-adjust: 100%;
  }

  body {
    background-color: var(--bg);
    color: var(--fg);
    font-family: var(--font-body);
    line-height: 1.6;
    overflow-x: hidden;
    transition: background-color var(--trans), color var(--trans);
  }

  img { display: block; max-width: 100%; }
  a { color: inherit; text-decoration: none; }
  button { cursor: pointer; border: none; background: none; font-family: inherit; }
  input, textarea, select { font-family: inherit; }
  ul, ol { list-style: none; }

  .container {
    width: 100%;
    max-width: var(--container);
    margin: 0 auto;
    padding: 0 clamp(24px, 5vw, 60px);
  }

  /* ============================================================
     NAV
  ============================================================ */
  #nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 900;
    height: var(--nav-h);
    display: flex;
    align-items: center;
    transition: background-color var(--trans), border-color var(--trans);
  }

  #nav.scrolled {
    background-color: var(--bg);
    border-bottom: 1px solid var(--border);
  }

  .nav-inner {
    width: 100%;
    max-width: var(--container);
    margin: 0 auto;
    padding: 0 clamp(24px, 5vw, 60px);
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .nav-logo {
    font-family: var(--font-display);
    font-size: 1.2rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    color: var(--fg);
    transition: color var(--trans);
  }

  .nav-logo span {
    color: var(--accent);
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: clamp(24px, 3vw, 40px);
  }

  .nav-links a {
    font-family: var(--font-body);
    font-size: 0.85rem;
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--fg-muted);
    transition: color var(--trans);
  }

  .nav-links a:hover {
    color: var(--accent);
  }

  .nav-cta {
    font-family: var(--font-body);
    font-size: 0.82rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 10px 24px;
    border: 1px solid var(--accent);
    color: var(--accent) !important;
    transition: background-color var(--trans), color var(--trans) !important;
  }

  .nav-cta:hover {
    background-color: var(--accent);
    color: var(--bg) !important;
  }

  .hamburger {
    display: none;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    gap: 5px;
    width: 40px;
    height: 40px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px;
    z-index: 1001;
  }

  .hamburger span {
    display: block;
    width: 26px;
    height: 1.5px;
    background-color: var(--fg);
    transition: transform var(--trans), opacity var(--trans), width var(--trans);
    transform-origin: center;
  }

  .hamburger.open span:nth-child(1) {
    transform: translateY(6.5px) rotate(45deg);
  }

  .hamburger.open span:nth-child(2) {
    opacity: 0;
    width: 0;
  }

  .hamburger.open span:nth-child(3) {
    transform: translateY(-6.5px) rotate(-45deg);
  }

  /* MOBILE OVERLAY */
  #mobile-overlay {
    position: fixed;
    inset: 0;
    z-index: 950;
    background-color: var(--bg);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 40px;
    opacity: 0;
    pointer-events: none;
    transition: opacity var(--trans-slow);
  }

  #mobile-overlay.open {
    opacity: 1;
    pointer-events: all;
  }

  #mobile-overlay a {
    font-family: var(--font-display);
    font-size: clamp(2rem, 8vw, 3.5rem);
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--fg);
    transition: color var(--trans);
  }

  #mobile-overlay a:hover {
    color: var(--accent);
  }

  #mobile-overlay .overlay-cta {
    font-size: clamp(1.2rem, 5vw, 1.8rem);
    color: var(--accent);
    border: 1px solid var(--accent);
    padding: 14px 40px;
  }

  /* ============================================================
     HERO
  ============================================================ */
  #hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding-bottom: clamp(60px, 8vw, 100px);
    overflow: hidden;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .hero-bg::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      transparent 0%,
      rgba(8, 8, 8, 0.3) 40%,
      rgba(8, 8, 8, 0.85) 75%,
      var(--bg) 100%
    );
    z-index: 1;
    transition: background var(--trans);
  }

  .hero-bg-pattern {
    position: absolute;
    inset: 0;
    background-image:
      radial-gradient(ellipse 80% 60% at 60% 40%, rgba(200, 169, 110, 0.06) 0%, transparent 70%),
      repeating-linear-gradient(
        0deg,
        transparent,
        transparent 60px,
        rgba(200, 169, 110, 0.02) 60px,
        rgba(200, 169, 110, 0.02) 61px
      ),
      repeating-linear-gradient(
        90deg,
        transparent,
        transparent 60px,
        rgba(200, 169, 110, 0.02) 60px,
        rgba(200, 169, 110, 0.02) 61px
      );
  }

  .hero-content {
    position: relative;
    z-index: 2;
    width: 100%;
    max-width: var(--container);
    margin: 0 auto;
    padding: 0 clamp(24px, 5vw, 60px);
  }

  .hero-eyebrow {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: clamp(16px, 3vw, 28px);
  }

  .hero-eyebrow-line {
    width: 40px;
    height: 1px;
    background-color: var(--accent);
  }

  .hero-eyebrow-text {
    font-family: var(--font-body);
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--accent);
  }

  .hero-name {
    font-family: var(--font-display);
    font-size: clamp(4.5rem, 13vw, 13rem);
    font-weight: 700;
    letter-spacing: -0.01em;
    line-height: 0.9;
    text-transform: uppercase;
    color: var(--fg);
    margin-bottom: clamp(20px, 3vw, 36px);
  }

  .hero-name .name-first {
    display: block;
    color: var(--fg);
  }

  .hero-name .name-last {
    display: block;
    color: var(--accent);
    -webkit-text-stroke: 0px;
  }

  .hero-divider {
    width: clamp(60px, 8vw, 100px);
    height: 2px;
    background-color: var(--accent);
    margin-bottom: clamp(20px, 3vw, 32px);
  }

  .hero-statement {
    font-family: var(--font-body);
    font-size: clamp(1rem, 2.2vw, 1.35rem);
    font-weight: 300;
    line-height: 1.65;
    color: var(--fg-muted);
    max-width: 600px;
    margin-bottom: clamp(36px, 5vw, 56px);
  }

  .hero-statement strong {
    color: var(--fg);
    font-weight: 500;
  }

  .hero-actions {
    display: flex;
    align-items: center;
    gap: clamp(16px, 3vw, 28px);
    flex-wrap: wrap;
  }

  .btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-family: var(--font-body);
    font-size: 0.85rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 16px 36px;
    background-color: var(--accent);
    color: var(--bg);
    transition: background-color var(--trans), transform var(--trans), box-shadow var(--trans);
  }

  .btn-primary:hover {
    background-color: var(--fg);
    transform: translateY(-2px);
    box-shadow: 0 8px 32px rgba(200, 169, 110, 0.2);
  }

  .btn-secondary {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-family: var(--font-body);
    font-size: 0.85rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 16px 36px;
    border: 1px solid var(--border);
    color: var(--fg);
    transition: border-color var(--trans), color var(--trans), transform var(--trans);
  }

  .btn-secondary:hover {
    border-color: var(--accent);
    color: var(--accent);
    transform: translateY(-2px);
  }

  .hero-scroll {
    position: absolute;
    bottom: clamp(30px, 4vw, 48px);
    right: clamp(24px, 5vw, 60px);
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 10px;
  }

  .hero-scroll span {
    font-family: var(--font-body);
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--fg-subtle);
    writing-mode: vertical-rl;
  }

  .hero-scroll-line {
    width: 1px;
    height: 60px;
    background: linear-gradient(to bottom, var(--accent), transparent);
    animation: scrollLine 2s ease-in-out infinite;
  }

  @keyframes scrollLine {
    0%, 100% { opacity: 0.4; transform: scaleY(1); }
    50% { opacity: 1; transform: scaleY(0.6); }
  }

  /* HERO POSITION BADGE */
  .hero-badge {
    position: absolute;
    top: calc(var(--nav-h) + clamp(20px, 4vw, 40px));
    right: clamp(24px, 5vw, 60px);
    z-index: 2;
    text-align: right;
  }

  .hero-badge-number {
    font-family: var(--font-display);
    font-size: clamp(5rem, 15vw, 18rem);
    font-weight: 700;
    line-height: 1;
    color: transparent;
    -webkit-text-stroke: 1px rgba(200, 169, 110, 0.1);
    letter-spacing: -0.02em;
    user-select: none;
    pointer-events: none;
  }

  /* ============================================================
     FIELD POSITION SECTION (Narrative — no stats)
  ============================================================ */
  #identity {
    padding: var(--section-pad) 0;
    background-color: var(--bg-secondary);
    position: relative;
    overflow: hidden;
  }

  #identity::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 1px;
    background: linear-gradient(to right, transparent, var(--accent), transparent);
    opacity: 0.4;
  }

  #identity::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 1px;
    background: linear-gradient(to right, transparent, var(--accent), transparent);
    opacity: 0.4;
  }

  .identity-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(40px, 6vw, 80px);
    align-items: center;
  }

  .identity-label {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: clamp(20px, 3vw, 32px);
  }

  .identity-label-line {
    width: 32px;
    height: 1px;
    background-color: var(--accent);
  }

  .identity-label-text {
    font-family: var(--font-body);
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--accent);
  }

  .identity-heading {
    font-family: var(--font-display);
    font-size: clamp(2rem, 5vw, 4rem);
    font-weight: 600;
    line-height: 1.05;
    text-transform: uppercase;
    color: var(--fg);
    margin-bottom: clamp(20px, 3vw, 30px);
  }

  .identity-heading em {
    font-style: normal;
    color: var(--accent);
  }

  .identity-body {
    font-family: var(--font-body);
    font-size: clamp(1rem, 1.6vw, 1.15rem);
    font-weight: 300;
    line-height: 1.8;
    color: var(--fg-muted);
  }

  .identity-body p + p {
    margin-top: 1.2em;
  }

  .identity-body strong {
    color: var(--fg);
    font-weight: 500;
  }

  .identity-metrics {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2px;
  }

  .metric-card {
    background-color: var(--bg-card);
    padding: clamp(28px, 4vw, 44px) clamp(20px, 3vw, 36px);
    border: 1px solid var(--border);
    position: relative;
    overflow: hidden;
    transition: border-color var(--trans), transform var(--trans);
  }

  .metric-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 3px;
    height: 100%;
    background-color: var(--accent);
    opacity: 0;
    transition: opacity var(--trans);
  }

  .metric-card:hover {
    border-color: var(--accent);
    transform: translateY(-4px);
  }

  .metric-card:hover::before {
    opacity: 1;
  }

  .metric-icon {
    font-size: 1.6rem;
    margin-bottom: 12px;
    line-height: 1;
  }

  .metric-label {
    font-family: var(--font-body);
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 8px;
  }

  .metric-value {
    font-family: var(--font-display);
    font-size: clamp(1.4rem, 2.5vw, 2rem);
    font-weight: 600;
    color: var(--fg);
    line-height: 1.1;
    margin-bottom: 6px;
  }

  .metric-desc {
    font-family: var(--font-body);
    font-size: 0.8rem;
    color: var(--fg-muted);
    line-height: 1.5;
  }

  /* ============================================================
     NIL / CONTACT
  ============================================================ */
  #contact {
    padding: var(--section-pad) 0;
    background-color: var(--bg);
    position: relative;
  }

  .contact-header {
    text-align: center;
    margin-bottom: clamp(48px, 6vw, 72px);
  }

  .section-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    margin-bottom: clamp(16px, 2vw, 24px);
  }

  .section-eyebrow-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background-color: var(--accent);
  }

  .section-eyebrow-text {
    font-family: var(--font-body);
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--accent);
  }

  .section-title {
    font-family: var(--font-display);
    font-size: clamp(2.2rem, 5vw, 4.5rem);
    font-weight: 600;
    text-transform: uppercase;
    color: var(--fg);
    line-height: 1.05;
    margin-bottom: clamp(16px, 2vw, 24px);
  }

  .section-subtitle {
    font-family: var(--font-body);
    font-size: clamp(0.95rem, 1.5vw, 1.1rem);
    font-weight: 300;
    color: var(--fg-muted);
    max-width: 520px;
    margin: 0 auto;
    line-height: 1.7;
  }

  .contact-grid {
    display: grid;
    grid-template-columns: 1fr 1.4fr;
    gap: clamp(40px, 6vw, 80px);
    align-items: start;
  }

  .contact-info {
    padding-top: 8px;
  }

  .contact-intro {
    font-family: var(--font-body);
    font-size: clamp(0.95rem, 1.5vw, 1.05rem);
    font-weight: 300;
    line-height: 1.8;
    color: var(--fg-muted);
    margin-bottom: clamp(32px, 4vw, 48px);
  }

  .contact-intro strong {
    color: var(--fg);
    font-weight: 500;
  }

  .nil-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-bottom: clamp(32px, 4vw, 48px);
  }

  .nil-tag {
    font-family: var(--font-body);
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 8px 16px;
    border: 1px solid var(--border);
    color: var(--fg-muted);
    transition: border-color var(--trans), color var(--trans);
  }

  .nil-tag:hover {
    border-color: var(--accent);
    color: var(--accent);
  }

  .contact-detail {
    display: flex;
    align-items: flex-start;
    gap: 14px;
    padding: 16px 0;
    border-top: 1px solid var(--border);
  }

  .contact-detail:last-child {
    border-bottom: 1px solid var(--border);
  }

  .contact-detail-icon {
    color: var(--accent);
    font-size: 1rem;
    margin-top: 2px;
    flex-shrink: 0;
  }

  .contact-detail-label {
